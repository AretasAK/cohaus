{
  "expo": {
    "name": "Cohaus",
    "slug": "cohaus",
    "owner": "aretasdev-2",
    "scheme": "cohaus",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cohaus.app"
    },
    "android": {
      "package": "com.cohaus.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cohaus necesita acceso a tus fotos para subir tickets de la compra.",
          "cameraPermission": "Cohaus necesita la cámara para hacer fotos a los tickets de la compra."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C96F4A"
        }
      ],
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "bc83972d-0c23-406d-b946-2ebba3c32f3c"
      }
    }
  }
}
